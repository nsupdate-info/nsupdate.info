#: accounts/models.py:20
msgid "user"
msgstr "χρήστης"

#: accounts/models.py:23
msgid "language"
msgstr "γλώσσα"

#: accounts/models.py:29
msgid "user profile"
msgstr "προφίλ χρήστη"

#: accounts/models.py:30
msgid "user profiles"
msgstr "προφίλ χρηστών"

#: accounts/registration_form.py:75
msgid "Enter a valid email address."
msgstr "Εισάγετε μια έγκυρη διεύθυνση e-mail."

#: accounts/templates/accounts/delete_user.html:7
msgid "Delete your User Account"
msgstr "Σβήσε τον λογαριασμό σου"

#: accounts/templates/accounts/delete_user.html:11
msgid ""
"Are you sure you want to delete your user account and all your data on this "
"service? You cannot undelete your data."
msgstr ""
"Θέλετε σίγουρα να διαγράψετε τον λογαριασμό χρήστη σας και όλα τα δεδομένα "
"σας σε αυτήν την υπηρεσία; Δεν μπορείτε να ανακτήσετε τα δεδομένα σας."

#: accounts/templates/accounts/delete_user.html:16
#: main/templates/main/delete_object.html:15
msgid "Confirm"
msgstr "Επιβεβαίωση"

#: accounts/templates/accounts/user_settings_account.html:4
msgid "Account settings"
msgstr "Ρυθμίσεις λογαριασμού"

#: accounts/templates/accounts/user_settings_account.html:9
msgid "Change password"
msgstr "Αλλαγή κωδικού"

#: accounts/templates/accounts/user_settings_account.html:17
#: login/templates/password_reset_confirm.html:14
msgid "Change my password"
msgstr "Άλλαξε τον κωδικό μου"

#: accounts/templates/accounts/user_settings_account.html:17
#: login/templates/login.html:26
msgid "Forgot your password?"
msgstr "Ξεχάσατε τον κωδικό σας;"

#: accounts/templates/accounts/user_settings_account.html:25
msgid "Social Auth"
msgstr "Κοινωνική Ταυτοποίηση"

#: accounts/templates/accounts/user_settings_account.html:28
msgid "Associate with remote Account"
msgstr "Συσχέτιση με απομακρυσμένο Λογαριασμό"

#: accounts/templates/accounts/user_settings_account.html:35
msgid "Disassociate from remote Account"
msgstr "Ακύρωση συσχέτισης απομακρυσμένου Λογαριασμού"

#: accounts/templates/accounts/user_settings_account.html:47
msgid "Delete account"
msgstr "Διαγραφή λογαριασμού"

#: accounts/templates/accounts/user_settings_account.html:50
msgid ""
"If you'd like to stop using this service and delete this user profile and "
"all your data (especially all hosts and all domains created by this user), "
"you can do it here."
msgstr ""
"Αν θέλετε να σταματήσετε να χρησιμοποιείτε αυτήν την υπηρεσία και να "
"διαγράψετε αυτό το προφίλ χρήστη και όλα τα δεδομένα σας (ειδικά όλους τους "
"hosts και όλους τους τομείς που δημιουργήθηκαν από αυτόν τον χρήστη), "
"μπορείτε να το κάνετε εδώ."

#: accounts/templates/accounts/user_settings_account.html:56
msgid "Delete User Profile"
msgstr "Διαγραφή Λογαριασμού Χρήστη"

#: accounts/templates/accounts/user_settings_profile.html:4
msgid "Profile settings"
msgstr "Ρυθμίσεις προφίλ"

#: accounts/templates/accounts/user_settings_profile.html:9
#: templates/base.html:66
msgid "Profile"
msgstr "Προφίλ"

#: accounts/templates/accounts/user_settings_profile.html:18
msgid "Submit"
msgstr "Υποβολή"

#: accounts/templates/registration/activate.html:4
#: accounts/templates/registration/activation_complete.html:3
msgid "Activation complete"
msgstr "Η ενεργοποίηση ολοκληρώθηκε"

#: accounts/templates/registration/activate.html:4
msgid "Activation problem"
msgstr "Πρόβλημα με την ενεργοποίηση"

#: accounts/templates/registration/activate.html:8
#: accounts/templates/registration/activation_complete.html:6
msgid "Thanks, activation complete!"
msgstr "Σας ευχαριστώ, η ενεργοποίηση ολοκληρώθηκε"

#: accounts/templates/registration/activate.html:9
#: accounts/templates/registration/activation_complete.html:7
msgid ""
"You may now login using the username and password you set at registration."
msgstr ""
"Μπορείτε τώρα να συνδεθήτε χρησιμοποιώντας το όνομα χρήστη και τον κωδικό "
"που χρησιμοποιήσατε κατα την ενεργοποίηση"

#: accounts/templates/registration/activate.html:10
#: accounts/templates/registration/activation_complete.html:8
#: login/templates/login.html:3 login/templates/login.html:26
#: login/templates/password_reset_complete.html:8 templates/base.html:61
msgid "Log in"
msgstr "Σύνδεση"

#: accounts/templates/registration/activate.html:12
msgid "Oops"
msgstr "Ώπα"

#: accounts/templates/registration/activate.html:13
msgid ""
"It seems that your activation key is invalid. Please check the URL again."
msgstr ""
"Φαίνεται ότι το κλειδί ενεργοποίησής σας δεν είναι έγκυρο. Παρακαλώ ελέγξτε "
"ξανά τη διεύθυνση URL."

#: accounts/templates/registration/registration_closed.html:3
msgid "Registration closed"
msgstr "Η εγγραφή έκλεισε"

#: accounts/templates/registration/registration_closed.html:6
msgid "The account registration is closed."
msgstr "Η εγγραφή λογαριασμών είναι κλειστή."

#: accounts/templates/registration/registration_closed.html:7
#, python-format
msgid ""
"Registration is currently only possible by contacting the admin "
"(%(SERVICE_CONTACT)s). "
msgstr ""
"Η εγγραφή είναι προς το παρόν δυνατή μόνο επικοινωνώντας με τον διαχειριστή "
"(%(SERVICE_CONTACT)s). "

#: accounts/templates/registration/registration_complete.html:3
msgid "Activation email sent"
msgstr "Το μήνυμα ενεργοποίησης στάλθηκε"

#: accounts/templates/registration/registration_complete.html:6
msgid "An activation email has been sent."
msgstr "Στάλθηκε ένα μύνημα ενεργοποίησης"

#: accounts/templates/registration/registration_complete.html:7
msgid "Please check your email and click on the link to activate your account."
msgstr ""
"Παρακαλώ ελεγξτε το λογαριασμό του ηλεκτρονικού σας ταχυδρομείου και πατήστε "
"στον σύνδεσμο ενεργοποίησης του λογαριασμού σας"

#: accounts/templates/registration/registration_form.html:3
msgid "Register for an account"
msgstr "Eγγραφείτε για τον λογαριασμό σας."

#: accounts/templates/registration/registration_form.html:8
msgid "No registration required for testing"
msgstr "Δεν απαιτείται εγγραφή για δοκιμή"

#: accounts/templates/registration/registration_form.html:10
msgid "You can easily test the service and see what you get."
msgstr "Μπορείτε εύκολα να δοκιμάσετε την υπηρεσία και να δείτε τι προσφέρει."

#: accounts/templates/registration/registration_form.html:13
msgid "Just directly log in as:"
msgstr "Απλά συνδεθείτε απευθείας ως:"

#: accounts/templates/registration/registration_form.html:16
#: main/templates/main/includes/tabbed_router_configuration.html:78
msgid "Username:"
msgstr "Όνομα χρήστη:"

#: accounts/templates/registration/registration_form.html:17
#: main/templates/main/includes/tabbed_router_configuration.html:79
msgid "Password:"
msgstr "Κωδικός:"

#: accounts/templates/registration/registration_form.html:20
msgid ""
"<b>Note:</b> if that doesn't work, the service administrator did not set up "
"the test account yet or discontinued offering it. In that case, you can "
"still just register a new account."
msgstr ""
"<b>Σημείωση:</b> εάν δεν λειτουργεί, ο διαχειριστής της υπηρεσίας δεν έχει "
"ρυθμίσει ακόμα τον δοκιμαστικό λογαριασμό ή σταμάτησε να τον προσφέρει. Σε "
"αυτή την περίπτωση, μπορείτε να εγγραφείτε για έναν νέο λογαριασμό."

#: accounts/templates/registration/registration_form.html:26
msgid "test account is <b>only</b> for testing"
msgstr "ο λογαριασμός test είναι <b>μόνο</b> για δοκιμή"

#: accounts/templates/registration/registration_form.html:28
msgid ""
"Any data (hosts, domains, ...) entered using the test account might be "
"removed at any time and without prior notice."
msgstr ""
"Όσα δεδομένα (hosts, domains, ...) καταχωρούνται με χρήση του test "
"λογαριασμού μπορεί να αφαιρεθούν σε οποιαδήποτε στιγμή χωρίς προειδοποίηση. "

#: accounts/templates/registration/registration_form.html:34
msgid ""
"So if you'd like your stuff to stay, please register for a regular account "
"after finishing your initial evaluation."
msgstr ""
"Αν θέλετε λοιπόν τα δεδομένα σας να παραμείνουν, παρακαλώ εγγραφείτε για "
"κανονικό λογαριασμό μετά την ολοκλήρωση της αρχικής σας αξιολόγησης."

#: accounts/templates/registration/registration_form.html:41
msgid "Register new account"
msgstr "Καταχώρηση νέου λογαριασμού"

#: accounts/templates/registration/registration_form.html:43
msgid ""
"Username: should be related to your <em>person or organisation</em> (not: to "
"the host(s) you want to register).<br> Email address: must be a <em>working</"
"em> one, we'll send you an activation email there.<br> Password: please use "
"a sane one, we trust you."
msgstr ""
"Όνομα χρήστη: πρέπει να σχετίζεται με το <em>πρόσωπο ή τον οργανισμό</em> "
"σας (όχι: με τον/τους host(s) που θέλετε να εγγράψετε).<br> Διεύθυνση e-"
"mail: πρέπει να είναι <em>λειτουργική</em>, θα σας στείλουμε ένα e-mail "
"ενεργοποίησης εκεί.<br> Κωδικός: παρακαλώ χρησιμοποιήστε έναν λογικό, σας "
"εμπιστευόμαστε."

#: accounts/templates/registration/registration_form.html:56
msgid "Send activation email"
msgstr "Αποστολή μηνύματος ενεργοποίησης"

#: accounts/views.py:70
msgid "Your password was changed!"
msgstr "Ο κωδικός σας άλλαξε!"

#: login/templates/login.html:8
msgid "Login with a local Account"
msgstr "Σύνδεση με ένα τοπικό Λογαριασμό"

#: login/templates/login.html:11
msgid "Your username and password didn't match. Please try again."
msgstr ""
"Το όνομα χρήστη και ο κωδικός σας δεν ταιριάζουν. Παρακαλώ προσπάθηστε ξανά."

#: login/templates/login.html:20
msgid "Remember me"
msgstr "Να με θυμηθείς"

#: login/templates/login.html:27
msgid "Sign up for a new account..."
msgstr "Εγγραφείτε για ένα νέο λογαριασμό..."

#: login/templates/login.html:34
msgid "Login with a remote Account"
msgstr "Σύνδεση με έναν απομακρυσμένο Λογαριασμό"

#: login/templates/login.html:48
msgid "No remote account logins enabled."
msgstr "Δεν υπάρχουν ενεργοποιημένες απομακρυσμένες συνδέσεις λογαριασμού."

#: login/templates/login.html:49
msgid "Please login with a local account."
msgstr "Παρακαλώ συνδεθείτε με τοπικό λογαριασμό."

#: login/templates/logout.html:3 templates/base.html:76
msgid "Log out"
msgstr "Αποσύνδεση"

#: login/templates/logout.html:8
msgid "Thanks for spending some quality time with the Web site today."
msgstr ""
"Ευχαριστούμε που ξοδέψατε μερικό ποιοτικό χρόνο με τον Ιστοσελίδα σήμερα. "

#: login/templates/logout.html:9
msgid "Log in again"
msgstr "Συνδεθείτε πάλι"

#: login/templates/password_reset.html:3 login/templates/password_reset.html:7
#: login/templates/password_reset_confirm.html:3
msgid "Password reset"
msgstr "Επαναφορά κωδικού"

#: login/templates/password_reset.html:9
msgid ""
"Forgotten your password? Enter your email address below, and we'll email "
"instructions for setting a new one."
msgstr ""
"Ξεχάσατε τον κωδικό σας; Εισάγετε τη διεύθυνση του ηλεκτρονικού σας "
"ταχυδρομείου παρακάτω και θα σας στείλουμε, μέσω αυτού, οδηγίες για τη "
"ρύθμιση ενός νέου."

#: login/templates/password_reset.html:17
msgid "Reset my password"
msgstr "Επανέφερε τον κωδικό μου"

#: login/templates/password_reset_complete.html:3
#: login/templates/password_reset_complete.html:6
msgid "Password reset complete"
msgstr "Η επαναφορά κωδικού ολοκληρώθηκε"

#: login/templates/password_reset_complete.html:7
msgid "Your password has been set. You may go ahead and log in now."
msgstr "Ο κωδικός σας ρυθμίστηκε. Μπορείτε να συνδεθείτε τώρα."

#: login/templates/password_reset_confirm.html:7
msgid "Enter new password"
msgstr "Εισάγετε νέο κωδικό"

#: login/templates/password_reset_confirm.html:8
msgid ""
"Please enter your new password twice so we can verify you typed it in "
"correctly."
msgstr ""
"Παρακαλώ καταχωρήστε των κωδικό σας δύο φορές ώστε να επιβεβαιώσουμε ότι τον "
"πληκτρολογήσατε σωστά."

#: login/templates/password_reset_confirm.html:21
msgid "Password reset unsuccessful"
msgstr "Ανεπιτυχής επαναφορά κωδικού"

#: login/templates/password_reset_confirm.html:22
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used. Please request a new password reset."
msgstr ""
"Ο σύνδεσμος επαναφοράς κωδικού ήταν άκυρος, πιθανόν επειδή είχε ήδη "
"χρησιμοποιηθεί. Παρακαλώ αιτηθείτε εκ νέου επαναφορά κωδικού."

#: login/templates/password_reset_done.html:3
#: login/templates/password_reset_done.html:6
msgid "Password reset successful"
msgstr "Επιτυχής επαναφορά κωδικού"

#: login/templates/password_reset_done.html:7
msgid ""
"We've emailed you instructions for setting your password. You should be "
"receiving them shortly."
msgstr ""
"Σας αποστείλαμε e-mail με οδηγίες για την ρύθμιση του κωδικού σας. Θα πρέπει "
"να το λάβετε σύντομα."

#: login/templates/password_reset_done.html:8
msgid ""
"If you don't receive an email, please make sure you've entered the address "
"you registered with, and check your spam folder."
msgstr ""
"Αν δεν λάβατε ένα email, παρακαλώ βεβαιωθείτε ότι έχετε καταχωρήσει την "
"διεύθυνση με την οποία εγγραφήκατε, και ελέγξτε τον φάκελο ανεπιθύμητης "
"αλληλογραφίας."

#: main/forms.py:54 main/forms.py:71
msgid "Enter a valid secret in base64 format."
msgstr "Εισάγετε ένα έγκυρο μυστικό σε μορφή base64."

#: main/forms.py:83
#, python-format
msgid ""
"Failed to add/delete host connectivity-test.%(domain)s, check your DNS "
"server configuration. This is a requirement for setting the available flag."
msgstr ""
"Αποτυχία προσθήκης/διαγραφής του host connectivity-test.%(domain)s, ελέγξτε "
"την παραμετροποίηση του DNS διακομιστή σας. Αυτό είναι απαραίτητο για τον "
"ορισμό της σημαίας διαθεσιμότητας."

#: main/forms.py:91
msgid "Domain must be available to be public."
msgstr "Ο τομέας πρέπει να είναι διαθέσιμος για να είναι δημόσιος."

#: main/hashers.py:50
msgid "algorithm"
msgstr "αλγόριθμος"

#: main/hashers.py:51
msgid "salt"
msgstr "salt"

#: main/hashers.py:52
msgid "hash"
msgstr "hash"

#: main/models.py:41
msgid "name regex"
msgstr "κανονική έκφραση ονόματος"

#: main/models.py:44
msgid "Blacklisted domain. Evaluated as a regex (search)."
msgstr "Αποκλεισμένος τομέας. Αξιολογείται ως κανονική έκφραση (αναζήτηση)."

#: main/models.py:46 main/models.py:130 main/models.py:250 main/models.py:479
#: main/models.py:528
msgid "last update"
msgstr "τελευταία ενημέρωση"

#: main/models.py:47 main/models.py:131 main/models.py:251 main/models.py:480
#: main/models.py:529
msgid "created at"
msgstr "δημιουργήθηκε την"

#: main/models.py:51 main/models.py:132 main/models.py:252 main/models.py:484
#: main/models.py:533
msgid "created by"
msgstr "δημιουργήθηκε από"

#: main/models.py:57
msgid "blacklisted host"
msgstr "host σε μαύρη λίστα"

#: main/models.py:58
msgid "blacklisted hosts"
msgstr "hosts σε μαύρη λίστα"

#: main/models.py:87 main/models.py:158 main/models.py:379 main/models.py:453
#: main/models.py:510
msgid "name"
msgstr "όνομα"

#: main/models.py:89
msgid "Invalid domain name"
msgstr "Μη έγκυρο όνομα τομέα"

#: main/models.py:91
msgid "Name of the zone where dynamic hosts may get added"
msgstr "Ονομασία ζώνης όπου μπορούν να προστεθούν δυναμικοί hosts"

#: main/models.py:93
msgid "nameserver IP (primary)"
msgstr "Διεύθυνση IP nameserver (πρωτεύουσα)"

#: main/models.py:95
msgid "IP where the dynamic DNS updates for this zone will be sent to"
msgstr ""
"IP στην οποία θα αποστέλλονται οι ενημερώσεις του δυναμικού DNS γι' αυτή την "
"ζώνη"

#: main/models.py:97
msgid "nameserver IP (secondary)"
msgstr "Διεύθυνση IP nameserver (δευτερεύουσα)"

#: main/models.py:100
msgid "IP where DNS queries for this zone will be sent to"
msgstr "IP στην οποία θα αποστέλλονται ερωτήματα DNS γι' αυτή την ζώνη"

#: main/models.py:102
msgid "nameserver update secret"
msgstr "μυστικός κωδικός ενημέρωσης του nameserver"

#: main/models.py:105
msgid "Shared secret that allows updating this zone (base64 encoded)"
msgstr ""
"Κοινός κωδικός που επιτρέπει την ενημέρωση αυτής της ζώνης (base64 "
"κωδικοποίηση)"

#: main/models.py:107
msgid "nameserver update algorithm"
msgstr "αλγόριθμος ενημέρωσης του nameserver"

#: main/models.py:110
msgid "HMAC_SHA512 is fine for bind9 (you can change this later, if needed)"
msgstr ""
"Ο HMAC_SHA512 είναι εντάξει για bind9 (μπορείτε να το αλλάξετε αργότερα, αν "
"χρειάζεται)"

#: main/models.py:112
msgid "public"
msgstr "δημόσιο"

#: main/models.py:114
msgid ""
"Check to allow any user to add dynamic hosts to this zone - if not checked, "
"we'll only allow the owner to add hosts"
msgstr ""
"Επιλέξτε για να επιτρέψετε σε οποιονδήποτε χρήστη να προσθέτει δυναμικούς "
"hosts σε αυτή την ζώνη - αν όχι, θα επιτρέψουμε μόνο στον ιδιοκτήτη να "
"προσθέτει hosts"

#: main/models.py:119 main/models.py:183 main/models.py:404
msgid "available"
msgstr "διαθέσιμο"

#: main/models.py:121
msgid ""
"Check if nameserver is available/reachable - if not checked, we'll pause "
"querying/updating this nameserver for a while"
msgstr ""
"Επιλέξτε αν ο nameserver είναι διαθέσιμος/προσβάσιμος - αν όχι, θα "
"σταματήσουμε τα ερωτήματα/ενημερώσεις του namesarver για λίγο"

#: main/models.py:124 main/models.py:174 main/models.py:389 main/models.py:457
#: main/models.py:503
msgid "comment"
msgstr "σχόλιο"

#: main/models.py:127
msgid ""
"Some arbitrary comment about your domain. If your domain is public, the "
"comment will also be publicly shown."
msgstr ""
"Ένα σχόλιο σχετικά με τον τομέα σας. Αν ο τομέας σας είναι δημόσιος, το "
"σχόλιο θα εμφανίζεται επίσης δημόσια."

#: main/models.py:151 main/models.py:168
msgid "domain"
msgstr "τομέας"

#: main/models.py:152
msgid "domains"
msgstr "τομείς"

#: main/models.py:167
msgid "The name of your host."
msgstr "Το όνομα του host σας."

#: main/models.py:170
msgid "update secret"
msgstr "μυστικός κωδικός ενημέρωσης"

#: main/models.py:177 main/models.py:392
msgid ""
"Some arbitrary comment about your host, e.g. who / what / where this host is"
msgstr ""
"Ένα σχόλιο σχετικά με τον host σας, π.χ. ποιος / τι / πού βρίσκεται αυτός ο "
"host"

#: main/models.py:185 main/models.py:406
msgid ""
"Check if host is available/in use - if not checked, we won't accept updates "
"for this host"
msgstr ""
"Επιλέξτε αν ο host είναι διαθέσιμος/σε χρήση - αν όχι, δεν θα δεχόμαστε "
"ενημερώσεις γι' αυτόν τον host"

#: main/models.py:188
msgid "netmask IPv4"
msgstr "μασκα δικτύου IPv4"

#: main/models.py:190
msgid "Netmask/Prefix length for IPv4."
msgstr "Μασκα δικτύου / Μήκος προθέματος για IPv4."

#: main/models.py:192
msgid "netmask IPv6"
msgstr "μασκα δικτύου IPv6"

#: main/models.py:194
msgid "Netmask/Prefix length for IPv6."
msgstr "Μασκα δικτύου / Μήκος προθέματος για IPv6."

#: main/models.py:203
msgid "abuse"
msgstr "κατάχρηση"

#: main/models.py:205
msgid ""
"Checked if we think you abuse the service - you may uncheck this AFTER "
"fixing all issues on your side"
msgstr ""
"Επιλεγμένο αν πιστεύουμε ότι κάνετε κατάχρηση της υπηρεσίας - μπορείτε να το "
"αποεπιλέξετε ΑΦΟΤΟΥ διορθώσετε όλα τα προβλήματα από πλευρά σας"

