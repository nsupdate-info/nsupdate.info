#: accounts/registration_form.py:75
msgid "Enter a valid email address."
msgstr "Érvényes e-mail címet adjon meg."

#: accounts/templates/accounts/delete_user.html:7
msgid "Delete your User Account"
msgstr "Fiók törlése"

#: accounts/templates/accounts/delete_user.html:11
msgid ""
"Are you sure you want to delete your user account and all your data on this "
"service? You cannot undelete your data."
msgstr "Biztosan törölnéd a felhasználói fiókodat, annak minden adatával együtt? Ez egy nem visszavonható művelet."

#: accounts/templates/accounts/delete_user.html:16
#: main/templates/main/delete_object.html:15
msgid "Confirm"
msgstr "Beleegyezés"

#: accounts/templates/accounts/user_settings_account.html:4
msgid "Account settings"
msgstr "Fiók beállítasai"

#: accounts/templates/accounts/user_settings_account.html:9
msgid "Change password"
msgstr "Jelszóváltás"

#: accounts/templates/accounts/user_settings_account.html:17
#: login/templates/password_reset_confirm.html:14
msgid "Change my password"
msgstr "Jelszóváltás"

#: accounts/templates/accounts/user_settings_account.html:17
#: login/templates/login.html:26
msgid "Forgot your password?"
msgstr "Elfelejtetted a jelszavad?"

#: accounts/templates/accounts/user_settings_account.html:25
msgid "Social Auth"
msgstr "Belépés felhővel"

#: accounts/templates/accounts/user_settings_account.html:28
msgid "Associate with remote Account"
msgstr "Összekapcsolás távoli fiókkal"

#: accounts/templates/accounts/user_settings_account.html:35
msgid "Disassociate from remote Account"
msgstr "Szétkapcsolás távoli fióktól"

#: accounts/templates/accounts/user_settings_account.html:47
msgid "Delete account"
msgstr "Fiók törlése"

#: accounts/templates/accounts/user_settings_account.html:50
msgid ""
"If you'd like to stop using this service and delete this user profile and "
"all your data (especially all hosts and all domains created by this user), "
"you can do it here."
msgstr "Ha felhagynál a szolgáltatás használatával és törölnéd ezt a fiókot annak minden adatával együtt (különösen az összes hosztoddal és doméneddel), akkor itt megteheted."

#: accounts/templates/accounts/user_settings_account.html:56
msgid "Delete User Profile"
msgstr "Fiók törlése"

#: accounts/templates/accounts/user_settings_profile.html:4
msgid "Profile settings"
msgstr "Fiók beállításai"

#: accounts/templates/accounts/user_settings_profile.html:9
#: templates/base.html:65
msgid "Profile"
msgstr "Fiók"

#: accounts/templates/accounts/user_settings_profile.html:18
msgid "Submit"
msgstr "Elküld"

#: accounts/templates/registration/activate.html:4
#: accounts/templates/registration/activation_complete.html:3
msgid "Activation complete"
msgstr "Aktiválás sikeres"

#: accounts/templates/registration/activate.html:4
msgid "Activation problem"
msgstr "Aktivációs hiba"

#: accounts/templates/registration/activate.html:8
#: accounts/templates/registration/activation_complete.html:6
msgid "Thanks, activation complete!"
msgstr "Az aktiválás sikerült, köszönjük!"

#: accounts/templates/registration/activate.html:9
#: accounts/templates/registration/activation_complete.html:7
msgid ""
"You may now login using the username and password you set at registration."
msgstr "Most már beléphetsz a regisztrációnál megadott felhasználónévvel és jelszóval."

#: accounts/templates/registration/activate.html:10
#: accounts/templates/registration/activation_complete.html:8
#: login/templates/login.html:3 login/templates/login.html:26
#: login/templates/password_reset_complete.html:8 templates/base.html:60
msgid "Log in"
msgstr "Belépés"

#: accounts/templates/registration/activate.html:12
msgid "Oops"
msgstr "Húha"

#: accounts/templates/registration/activate.html:13
msgid ""
"It seems that your activation key is invalid. Please check the URL again."
msgstr "Az aktivációs kulcsod érvénytelennek tűnik. Kérlek ellenőrizd az URL-t."

#: accounts/templates/registration/registration_closed.html:3
msgid "Registration closed"
msgstr "Regisztráció lezárva"

#: accounts/templates/registration/registration_closed.html:6
msgid "The account registration is closed."
msgstr "Új fiókok regisztrációja le van zárva."

#: accounts/templates/registration/registration_closed.html:7
#, python-format
msgid ""
"Registration is currently only possible by contacting the admin "
"(%(SERVICE_CONTACT)s). "
msgstr "Pillanatnyilag csak az adminisztrátorral kapcsolatba lépve lehet regisztrálni (%(SERVICE_CONTACT)s). "

#: accounts/templates/registration/registration_complete.html:3
msgid "Activation email sent"
msgstr "Aktivációs levél kiküldve"

#: accounts/templates/registration/registration_complete.html:6
msgid "An activation email has been sent."
msgstr "Kiküldtünk egy aktivációs levelet."

#: accounts/templates/registration/registration_complete.html:7
msgid ""
"Please check your email and click on the link to activate your account."
msgstr "Vizsgáld meg az e-mailedet, és kattints benne a linkre, hogy aktiváljuk a fiókodat."

#: accounts/templates/registration/registration_form.html:3
msgid "Register for an account"
msgstr "Fiók regisztrációja"

#: accounts/templates/registration/registration_form.html:8
msgid "No registration required for testing"
msgstr "Kipróbáláshoz nincs szükség regisztrációra"

#: accounts/templates/registration/registration_form.html:10
msgid "You can easily test the service and see what you get."
msgstr "Egyszerűen kipróbálhatod a szolgáltatást, és láthatod, mit kapsz."

#: accounts/templates/registration/registration_form.html:13
msgid "Just directly log in as:"
msgstr "Csak lépj be közvetlenül, mint:"

#: accounts/templates/registration/registration_form.html:16
#: main/templates/main/includes/tabbed_router_configuration.html:78
msgid "Username:"
msgstr "Felhasználónév:"

#: accounts/templates/registration/registration_form.html:17
#: main/templates/main/includes/tabbed_router_configuration.html:79
msgid "Password:"
msgstr "Jelszó:"

#: accounts/templates/registration/registration_form.html:20
msgid ""
"<b>Note:</b> if that doesn't work, the service administrator did not set up "
"the test account yet or discontinued offering it. In that case, you can "
"still just register a new account."
msgstr "<b>Megjegyzés:</b> ha ez nem működik, akkor a szolgáltatás adminisztrátora még vagy már nem állított be tesztfiókot. Regisztrálj rendes fiókot."

#: accounts/templates/registration/registration_form.html:26
msgid "test account is <b>only</b> for testing"
msgstr "tesztfiók <b>csak</b> kipróbálásra"

#: accounts/templates/registration/registration_form.html:28
msgid ""
"Any data (hosts, domains, ...) entered using the test account might be "
"removed at any time and without prior notice."
msgstr "A tesztfiókba beírt minden adat (hosztok, domének, ...) bármikor, figyelmeztetés nélkül törölhető."

#: accounts/templates/registration/registration_form.html:34
msgid ""
"So if you'd like your stuff to stay, please register for a regular account "
"after finishing your initial evaluation."
msgstr "Ha azt szeretnéd, hogy megmaradjanak a dolgait, akkor regisztrálj egy rendes fiókot, miután kipróbáltad a rendszert."

#: accounts/templates/registration/registration_form.html:41
msgid "Register new account"
msgstr "Új fiók regisztrációja"

#: accounts/templates/registration/registration_form.html:43
msgid ""
"Username: should be related to your <em>person or organisation</em> (not: to"
" the host(s) you want to register).<br> Email address: must be a "
"<em>working</em> one, we'll send you an activation email there.<br> "
"Password: please use a sane one, we trust you."
msgstr "Felhasználónév: <em>veled vagy a szervezeteddel</em> álljon kapcsolatban (és ne a regisztrálandó hoszt(ok)kal).<br> E-mail cím: <em>működőnek</em>kell lennie, oda fogjuk küldeni az aktivációs levelet.<br> Jelszó: kérjük, értelmeset használj, bízunk benned."

#: accounts/templates/registration/registration_form.html:56
msgid "Send activation email"
msgstr "Aktivációs levél kiküldése"

#: accounts/views.py:70
msgid "Your password was changed!"
msgstr "Megváltoztattuk a jelszavad!"

#: login/templates/login.html:8
msgid "Login with a local Account"
msgstr "Belépés helyi fiókkal"

#: login/templates/login.html:11
msgid "Your username and password didn't match. Please try again."
msgstr "Felhasználóneved és jelszavad nem stimmel. Próbáld újra."

#: login/templates/login.html:20
msgid "Remember me"
msgstr "Jegyezz meg"

#: login/templates/login.html:27
msgid "Sign up for a new account..."
msgstr "Új fiók regisztrációja"

#: login/templates/login.html:34
msgid "Login with a remote Account"
msgstr "Belépés távoli fiókkal"

#: login/templates/login.html:48
msgid "No remote account logins enabled."
msgstr "Távoli belépés nem engedélyezett."

#: login/templates/login.html:49
msgid "Please login with a local account."
msgstr "Kérjük, helyi fiókkal lépj be."

#: login/templates/logout.html:3 templates/base.html:75
msgid "Log out"
msgstr "Kilépés"

#: login/templates/logout.html:8
msgid "Thanks for spending some quality time with the Web site today."
msgstr "Köszönjük a weblappal töltött minőségi időtöltést."

#: login/templates/logout.html:9
msgid "Log in again"
msgstr "Újra belép"

#: login/templates/password_reset.html:3 login/templates/password_reset.html:7
#: login/templates/password_reset_confirm.html:3
msgid "Password reset"
msgstr "Jelszó visszaállítása"

#: login/templates/password_reset.html:9
msgid ""
"Forgotten your password? Enter your email address below, and we'll email "
"instructions for setting a new one."
msgstr "Elfelejtetted a jelszavad? Add meg az e-mail címed, és megírjuk egy levélben, hogyan állíthatsz be újat."

#: login/templates/password_reset.html:17
msgid "Reset my password"
msgstr "Jelszavam visszaállítása"

#: login/templates/password_reset_complete.html:3
#: login/templates/password_reset_complete.html:6
msgid "Password reset complete"
msgstr "Sikeres jelszóvisszaállítás"

#: login/templates/password_reset_complete.html:7
msgid "Your password has been set. You may go ahead and log in now."
msgstr "Beállítottuk a jelszavad, most már beléphetsz."

#: login/templates/password_reset_confirm.html:7
msgid "Enter new password"
msgstr "Add meg az új jelszót"

#: login/templates/password_reset_confirm.html:8
msgid ""
"Please enter your new password twice so we can verify you typed it in "
"correctly."
msgstr "Kérjük, kétszer írd be az új jelszavad, mert innét tudjuk, hogy jól írtad-e be."

#: login/templates/password_reset_confirm.html:21
msgid "Password reset unsuccessful"
msgstr "Sikertelen jelszóvisszaállítás"

#: login/templates/password_reset_confirm.html:22
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used. Please request a new password reset."
msgstr "A jelszóvisszaállító link érvénytelen, valószínűleg már felhasználtad. Kérjük, kezdeményezz egy új jelszóvisszaállítást."

#: login/templates/password_reset_done.html:3
#: login/templates/password_reset_done.html:6
msgid "Password reset successful"
msgstr "Sikeres jelszóvisszaállítás"

#: login/templates/password_reset_done.html:7
msgid ""
"We've emailed you instructions for setting your password. You should be "
"receiving them shortly."
msgstr "Megírtuk egy levélben, hogyan állíthatod be a jelszavad. Rövidesen meg kell kapjad."

#: login/templates/password_reset_done.html:8
msgid ""
"If you don't receive an email, please make sure you've entered the address "
"you registered with, and check your spam folder."
msgstr "Ha nem kapsz e-mail-t, kérlek ellenőrizd, hogy jól írtad-e itt be azt az e-mail címed, amivel itt regisztráltál, és nézd meg a spam mappádat."

#: main/forms.py:54 main/forms.py:71
msgid "Enter a valid secret in base64 format."
msgstr "Érvényes titkot adj meg, base64 formátumban."

#: main/forms.py:83
#, python-format
msgid ""
"Failed to add/delete host connectivity-test.%(domain)s, check your DNS "
"server configuration. This is a requirement for setting the available flag."
msgstr "A hoszt connectivity-test.%(domain)s, hozzáadása/törlése nem sikerült. Ellenőrizd a DNS szervered beállításait. Ez az \"elérhető\" gomb beállításához szükséges."

#: main/forms.py:91
msgid "Domain must be available to be public."
msgstr "A doménnek elérhetőnek kell lennie, hogy publikus legyen."

